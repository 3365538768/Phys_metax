{
  "_description": "auto_simulation_runner 用 train_config：包含 Job 可读的全部字段。路径相对于 PhysGaussian 根目录执行时的 cwd。",
  "seed": 0,
  "num_simulations": 1,
  "sim_types": ["bend", "drop", "press", "shear", "stretch"],

  "output_root": "auto_output",
  "output_layout": "by_model",

  "render_img": true,
  "compile_video": false,
  "num_views": 4,
  "num_render_views": -1,
  "num_render_timesteps": 40,
  "white_bg": false,
  "debug": false,

  "output_deformation": true,
  "output_stress": true,
  "field_output_interval": 10,
  "output_view_stress_heatmap": false,
  "output_view_tracks2d": false,
  "no_volumetric_stress_deformation": false,

  "output_bc_info": true,
  "output_force_info": true,

  "base_config_by_sim_type": {
    "press": "config/press_cube_jelly.json",
    "drop": "config/drop_cube_jelly.json",
    "shear": "config/shear_cube_jelly.json",
    "stretch": "config/stretch_cube_jelly.json",
    "bend": "config/bend_cube_jelly.json"
  }
}
