{
  "data": {
    "split_root": "auto_output/dataset_deformation_stress_500_new/train",
    "auto_output": "auto_output"
  },
  "model": {
    "num_views": 3,
    "num_frames": 16,
    "img_size": 224,
    "in_channels": 1,
    "input_mode": "images",
    "dec_h": 224,
    "dec_w": 224,
    "use_aux_field_heads": true,
    "use_attention_pool": true,
    "use_uncertainty": false,
    "encoder_dropout": 0.0,
    "head_dropout": 0.0,
    "encoder_embed_dim": 384,
    "encoder_depth": 12,
    "encoder_num_heads": 6,
    "tubelet_size": 1,
    "patch_size": 32,
    "fusion_dim": 512,
    "fusion_heads": 8
  },
  "train": {
    "epochs": 200,
    "preflight": false,
    "batch_size": 1,
    "lr": 0.0003,
    "num_workers": 0,
    "overfit_num_samples": 8,
    "overfit_no_shuffle": true,
    "disable_aux_losses": true,
    "debug_overfit": true,
    "debug_overfit_every_steps": 20,
    "lambda_stress": 0.0,
    "lambda_flow": 0.0,
    "lambda_force": 0.0,
    "no_log_scale": false,
    "train_ids_json": "train_test_split.json",
    "quick_eval": {
      "enabled": false,
      "every_epochs": 100,
      "weights": "last",
      "batch_size": 1,
      "num_workers": 0,
      "num_vis": 1,
      "vis_view": 0,
      "sample_limit": 1,
      "split_root": null,
      "train_ids_json": "train_test_split.json",
      "test_ids_json": "train_test_split.json"
    },
    "device": "cuda",
    "checkpoint": {
      "save_dir": null,
      "resume_from": null,
      "save_every_epochs": 50,
      "save_last": true,
      "save_best": false
    }
  }
}
