    "eval_every_epochs": 50,
    "eval_max_batches": 0,
    "_comment_eval_use_distributed_sampler": "true 时多卡分片 eval 并 all_reduce 聚合 loss/acc（无散点图与对比视频）；默认 false 为仅 rank0 全量 eval",
    "eval_use_distributed_sampler": true,
