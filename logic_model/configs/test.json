{
  "_comment_ddp": "在 Phys 根目录: torchrun --nproc_per_node=N -m logic_model.train --config logic_model/configs/logic_train_dataset_mask_1000.json ；全局等效 batch_size ≈ train.batch_size * N",
  "data": {
